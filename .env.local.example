# ========================================
# EMERGENCY INCIDENT REPORTER
# Environment Variables Configuration
# ========================================
# 
# Copy this file to .env.local and fill in your values
# IMPORTANT: .env.local is in .gitignore - never commit it!
#

# ========== REQUIRED: Google Sheets Configuration ==========

# Your Google Sheet ID (already filled with the shared sheet)
NEXT_PUBLIC_GOOGLE_SHEET_ID=1G-QaM8dvpgKzY5rbsmtbiYmve8z3VBbml1A96oxo5lE


# ========== REQUIRED: Service Account Credentials ==========
# 
# Get these from Google Cloud Console:
# 1. Create a Service Account (see GOOGLE_SHEETS_SETUP.md for details)
# 2. Download the JSON key file
# 3. Copy values from the JSON file below
#

# Service account email (from your JSON key file)
# Format: service-account-name@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account_email@project.iam.gserviceaccount.com

# Private key (from your JSON key file)
# IMPORTANT: Keep the newlines! Copy the entire key including:
#   - -----BEGIN PRIVATE KEY-----
#   - All the character lines
#   - -----END PRIVATE KEY-----
# When pasting in Vercel, use multiline paste
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# Private Key ID (from your JSON key file)
# Format: alphanumeric string
GOOGLE_PRIVATE_KEY_ID=your_private_key_id

# Google Cloud Project ID (from your JSON key file)
# Format: project-name or project-name-12345
GOOGLE_PROJECT_ID=your-google-cloud-project-id

# Client ID (from your JSON key file)
# Format: numeric string
GOOGLE_CLIENT_ID=your_client_id


# ========== ALTERNATE: API Key Method (Optional) ==========
# 
# Use this INSTEAD of Service Account if you prefer
# (Less secure, only for public sheets)
#
# Uncomment below to use API Key method instead:
#
# GOOGLE_SHEETS_API_KEY=your_public_api_key_here


# ========== NOTES ==========
#
# 1. Development:
#    - Create .env.local with above values
#    - Run: npm run dev
#    - App runs at http://localhost:3000
#
# 2. Production (Vercel):
#    - Add these variables in Vercel Dashboard
#    - Mark sensitive ones as "Secret"
#    - Redeploy after adding variables
#
# 3. Security:
#    - Never commit .env.local (use .gitignore)
#    - Keep private keys secure
#    - Use different credentials for dev/prod
#
# 4. Troubleshooting:
#    - Check variable names are exactly as shown
#    - Verify Google Sheet is shared with service account email
#    - Check Google Sheets API is enabled in GCP
#
